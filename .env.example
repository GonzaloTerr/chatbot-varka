# Copiar a .env y completar con tus valores. NUNCA subir el .env (esta en .gitignore).

ANTHROPIC_API_KEY=sk-ant-...        # API key de Anthropic (Claude)
SUPABASE_KEY=eyJ...                 # service_role de tu proyecto Supabase

WAHA_URL=https://tu-waha-host.example.com
WAHA_API_KEY=tu-waha-api-key
WAHA_SESSION=default
SUPABASE_URL=https://tu-proyecto.supabase.co
GROQ_API_KEY=                       # para transcribir audios (opcional)
CAL_LINK=https://cal.com/tu-organizacion/tu-evento
MODEL=claude-haiku-4-5

# Cal.com (el agente reserva turnos solo)
CAL_API_KEY=                        # Cal.com -> Settings -> Developer -> API Keys (empieza con cal_)
CAL_EVENT_TYPE_ID=                  # ID del tipo de evento
TIMEZONE=America/Argentina/Buenos_Aires